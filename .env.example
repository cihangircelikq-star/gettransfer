# ═══════════════════════════════════════════════════════════════════════════
# GetTransfer - Environment Variables Example
# ═══════════════════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE (Zorunlu / Required)
# ═══════════════════════════════════════════════════════════════════════════
# Supabase proje URL'si
# Project URL from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (anon key değil!)
# Service Role Key from Supabase Dashboard > Project Settings > API
# ⚠️ BU ANAHTARI ASLA İSTEMCİ TARAFINDA KULLANMAYIN!
# ⚠️ NEVER USE THIS KEY ON THE CLIENT SIDE!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════════════════════
# STRIPE (Opsiyonel - Ödeme / Optional - Payment)
# ═══════════════════════════════════════════════════════════════════════════
# Stripe Dashboard'dan alınır: https://dashboard.stripe.com/apikeys
# Test modu için sk_test_ ile başlayan anahtarı kullanın
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe Webhook Secret
# Developers > Webhooks > Add endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Publishable Key (Frontend için)
# Test modu için pk_test_ ile başlayan anahtarı kullanın
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ═══════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (Opsiyonel - Google ile Giriş / Optional - Google Sign In)
# ═══════════════════════════════════════════════════════════════════════════
# Google Cloud Console'dan alınır: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ═══════════════════════════════════════════════════════════════════════════
# UYGULAMA AYARLARI / APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════
# Geliştirme modunda API URL'si
# Development API URL
VITE_API_URL=http://localhost:3005

# Ortam modu (development, production, test)
# Environment mode
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# OPSİYONEL AYARLAR / OPTIONAL SETTINGS
# ═══════════════════════════════════════════════════════════════════════════
# JWT Secret (otomatik oluşturulur, gerekirse değiştirebilirsiniz)
# JWT Secret (auto-generated, change if needed)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Log seviyesi (debug, info, warn, error)
# Log level
LOG_LEVEL=debug

# Port (varsayılan 3005)
# Port (default 3005)
PORT=3005

# ═══════════════════════════════════════════════════════════════════════════
# NOTLAR / NOTES
# ═══════════════════════════════════════════════════════════════════════════
# 1. Bu dosyayı asla Git'e commit etmeyin (.gitignore'da listelenmiştir)
# 2. Production'da tüm değerleri Vercel Environment Variables'a ekleyin
# 3. Service Role Key'i asla istemci tarafında kullanmayın
# 4. Production'da NODE_ENV=production olarak ayarlayın
# ═══════════════════════════════════════════════════════════════════════════
